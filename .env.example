# ─────────────────────────────────────────────────────────────
# Ahrimod — базовые параметры (изменение требует перезапуска бота)
# Поведенческие настройки (пороги предупреждений, лимиты, бэкап и т.д.)
# меняются на лету через команду /menu или /setcfg в Telegram.
# ─────────────────────────────────────────────────────────────

# Токен бота от @BotFather
BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# Чат для уведомлений модераторам (закрытая группа админов)
ADMIN_CHAT_ID=-1001234567890
# Если ADMIN_CHAT_ID — форум-группа и нужна конкретная тема (0 = General)
ADMIN_CHAT_THREAD_ID=0

# Чат для audit-лога (можно тот же что и ADMIN_CHAT_ID)
LOG_CHAT_ID=-1001234567890
LOG_CHAT_THREAD_ID=0

# Модерируемые чаты (через запятую)
PROTECTED_CHAT_IDS=-1009999999999

# Telegram user_id админов бота (через запятую)
ADMIN_USER_IDS=123456789

# Где хранить БД. Относительный путь = от корня проекта.
DB_PATH=./data/bot.db
