# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID чата куда будут уходить сообщения на модерацию (приватный чат админов)
ADMIN_CHAT_ID=-1001234567890
# Если ADMIN_CHAT_ID — это форум-группа с темами, и нужно постить в конкретную тему,
# укажи её ID. URL в Telegram: t.me/c/<chat_id>/<thread_id>. Оставь 0 = General.
ADMIN_CHAT_THREAD_ID=0

# ID чата куда писать audit-лог действий бота (можно тот же что и ADMIN_CHAT_ID)
LOG_CHAT_ID=-1001234567890
LOG_CHAT_THREAD_ID=0

# ID чатов которые бот модерирует (через запятую)
PROTECTED_CHAT_IDS=-1001234567890

# ID админов через запятую (могут управлять ботом из любого чата)
ADMIN_USER_IDS=123456789,987654321

# Пороги доверия:
#   - юзер должен оставить TRUST_MIN_MESSAGES "квалифицирующих" сообщений
#   - между квалифицирующими сообщениями должно пройти не меньше TRUST_MIN_INTERVAL_MINUTES
#   - и только потом ещё TRUST_MIN_HOURS часов ожидания
TRUST_MIN_HOURS=24
TRUST_MIN_MESSAGES=3
TRUST_MIN_INTERVAL_MINUTES=60

# Путь к БД
DB_PATH=./data/bot.db

# Включить проверку через Combot Anti-Spam API (cas.chat)
USE_CAS=true

# Порог расстояния Хэмминга для SimHash (0-64). Меньше = строже.
SIMHASH_THRESHOLD=4

# Минимальная длина сообщения для добавления в базу сигнатур
SIGNATURE_MIN_LENGTH=30

# Наказание для новых юзеров за blacklist-контент: ban или mute
NEW_USER_PUNISHMENT=ban

# Длительность мута в минутах (если NEW_USER_PUNISHMENT=mute)
MUTE_DURATION_MINUTES=60

# ── Предупреждения и эскалация наказаний ──
# При WARN_RESET_TRUST_AT — обнуляется путь к доверию
WARN_RESET_TRUST_AT=3
# При WARN_MUTE_AT — авто-мут на WARN_MUTE_HOURS
WARN_MUTE_AT=5
WARN_MUTE_HOURS=24
# При WARN_BAN_AT — бан
WARN_BAN_AT=7
# Через сколько дней предупреждение автоматически списывается
WARN_TTL_DAYS=7
# Слать ли в чат уведомление о выдаче предупреждения
NOTIFY_ON_WARN=true
# Через сколько секунд удалять уведомление о предупреждении (0 = не удалять)
WARN_NOTIFICATION_TTL_SECONDS=60

# ── Бэкап БД ──
# Включить ежедневный бэкап в Telegram-чат
BACKUP_ENABLED=true
# Куда слать бэкап (0 = тот же что ADMIN_CHAT_ID)
BACKUP_CHAT_ID=0
# В какую тему форум-группы слать (0 = General)
BACKUP_THREAD_ID=0
# Час по UTC когда делать ежедневный бэкап (0..23)
BACKUP_HOUR=4
# Сколько дней хранить локальные .gz бэкапы в data/backups/
BACKUP_KEEP_DAYS=30

# ── Прочее ──
# Блокировать ли фото/видео/кружки/гифки от не-доверенных пользователей
RESTRICT_MEDIA_FOR_UNTRUSTED=true
# FAQ: один и тот же ответ в одном чате не чаще раза в N минут
FAQ_COOLDOWN_MINUTES=10
# Сколько дней хранить recent_messages для модерации через реакции
RECENT_MESSAGES_TTL_DAYS=7

# ── Уведомления о новых участниках ──
# Слать ли в лог-чат сообщение при вступлении нового юзера
# (после CAS и фильтра спама в имени). Полезно мониторить кто заходит.
NOTIFY_ON_NEW_MEMBER=false
# Отдельная тема в лог-чате для этих уведомлений (0 = в LOG_CHAT_THREAD_ID)
NEW_MEMBER_THREAD_ID=0
